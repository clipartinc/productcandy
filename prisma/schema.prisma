generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Required by @shopify/shopify-app-session-storage-prisma
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  refreshToken        String?
  refreshTokenExpires DateTime?
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
}

// Per-shop app settings + saved description templates
model Shop {
  id            String              @id @default(cuid())
  domain        String              @unique
  installedAt   DateTime            @default(now())
  templates     DescriptionTemplate[]

  // Billing — Custom Snippets is a $4.99/mo paid feature; merchants on
  // free plans can edit snippets in the admin but can't stamp them into
  // products or render them on storefronts until they subscribe.
  // Dev stores (plan.partnerDevelopment) bypass the paywall entirely.
  subscriptionId        String?   // Shopify GID for the active appSubscription
  subscriptionStatus    String?   // "ACTIVE" | "CANCELLED" | "DECLINED" | "EXPIRED" | null
  subscriptionCheckedAt DateTime? // Last time we hit Admin GraphQL to refresh status
  isDevStore            Boolean?  // Cached from shop.plan.partnerDevelopment

  // Uninstall lifecycle — Shopify GDPR webhooks:
  //   app/uninstalled  → set uninstalledAt = now() (we keep data so a
  //                      reinstall within 48 h keeps the merchant's work)
  //   shop/redact      → cascade-delete the Shop row (fires ~48 h after
  //                      uninstall if the merchant hasn't reinstalled).
  // On any successful authenticated request after a reinstall we clear
  // uninstalledAt so the entitlement gate immediately re-enables.
  uninstalledAt         DateTime?
}

model DescriptionTemplate {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  html      String
  // Serialized visual-builder layout (Row[] / Column[] / Block[]). Saved so
  // the editor can restore the structured blocks for editing; the rendered
  // `html` column is what gets stamped into product descriptions.
  layout    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shopId])
}
