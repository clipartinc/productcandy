# Shopify Partner app credentials (Apps -> Product Candy -> Configuration)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
NEXT_PUBLIC_SHOPIFY_API_KEY=

# Comma-separated OAuth scopes
SCOPES=read_products,write_products,read_files,write_files

# Public host of this app, no trailing slash. Locally use your tunnel URL,
# in production use https://<service>.up.railway.app
HOST=https://localhost:3000

# Postgres connection string (Railway -> Postgres -> Connect)
DATABASE_URL=postgresql://user:pass@host:5432/db
